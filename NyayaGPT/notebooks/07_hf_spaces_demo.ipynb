   "source": [
    "# Day 7 — HF Spaces Demo + PyTorch Profiler\n",
    "**Goal:** Deploy interactive Gradio demo on HF Spaces + capture a PyTorch Profiler trace.\n",
    "\n",
    "**Deliverables:**\n",
    "- `app.py` — Gradio app (2 tabs: Chat + Benchmark)\n",
    "- `assets/profiler_trace.png` — Screenshot for README\n",
    "- HF Space URL"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys, os, subprocess\n",
    "from pathlib import Path\n",
    "\n",
    "PROJECT_ROOT = Path.cwd().parent\n",
    "sys.path.insert(0, str(PROJECT_ROOT / 'src'))\n",
    "os.chdir(PROJECT_ROOT)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 1 — PyTorch Profiler Trace"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "from torch.profiler import profile, ProfilerActivity, tensorboard_trace_handler\n",
    "from pathlib import Path\n",
    "\n",
    "from nyaya_pipeline.infer import generate, _load_model\n",
    "from nyaya_pipeline import config\n",
    "\n",
    "Path('assets/profiler_logs').mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# Load model\n",
    "model, tokenizer = _load_model(config.STUDENT_MODEL_NAME, config.ADAPTER_DIR)\n",
    "\n",
    "# Warm-up\n",
    "print('Warming up …')\n",
    "generate('What is Article 21?', max_new_tokens=50)\n",
    "\n",
    "# Profile\n",
    "print('Profiling …')\n",
    "with profile(\n",
    "    activities=[ProfilerActivity.CPU, ProfilerActivity.CUDA],\n",
    "    on_trace_ready=tensorboard_trace_handler('./assets/profiler_logs'),\n",
    "    record_shapes=True,\n",
    "    profile_memory=True,\n",
    "    with_stack=False,\n",
    ") as prof:\n",
    "    generate('Explain the right to bail under Indian law.', max_new_tokens=100)\n",
    "\n",
    "# Print top ops\n",
    "print('\\nTop CUDA operations:')\n",
    "print(prof.key_averages().table(sort_by='cuda_time_total', row_limit=10))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save profiler summary as text\n",
    "summary = prof.key_averages().table(sort_by='cuda_time_total', row_limit=15)\n",
    "Path('assets/profiler_summary.txt').write_text(summary, encoding='utf-8')\n",
    "print('Profiler summary saved → assets/profiler_summary.txt')\n",
    "print()\n",
    "print('To view the full trace with TensorBoard:')\n",
    "print('  tensorboard --logdir assets/profiler_logs --port 6006')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 2 — Test app.py Locally"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Verify app.py exists\n",
    "app_path = PROJECT_ROOT / 'app.py'\n",
    "assert app_path.exists(), f'app.py not found at {app_path}'\n",
    "print(f'✓ app.py found: {app_path}')\n",
    "\n",
    "# Check Gradio\n",
    "try:\n",
    "    import gradio as gr\n",
    "    print(f'✓ gradio {gr.__version__}')\n",
    "except ImportError:\n",
    "    subprocess.check_call([sys.executable, '-m', 'pip', 'install', '-q', 'gradio'])\n",
    "    print('gradio installed')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
